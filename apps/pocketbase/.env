# 🔐 PocketBase Production Configuration
# Generated for Horizons Smart Agriculture Platform

# ============================================================
# SECURITY & ENCRYPTION
# ============================================================
# Strong 32-character encryption key for data at rest
# ⚠️ DO NOT CHANGE - Must match existing database encryption
PB_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# ============================================================
# SUPERUSER CREDENTIALS
# ============================================================
# Admin account for backend API authentication
# ℹ️  To change these, use the PocketBase Admin Dashboard
PB_SUPERUSER_EMAIL=admin@local4.dev
PB_SUPERUSER_PASSWORD=Admin124!Admin123!

# ============================================================
# DATABASE OPTIMIZATION
# ============================================================
# Enable automatic PRAGMA settings for SQLite optimization
PB_DB_PRAGMA_OPTIMIZE=true
PB_DB_PRAGMA_CACHE_SIZE=-64000
PB_DB_PRAGMA_SYNCHRONOUS=NORMAL
PB_DB_PRAGMA_JOURNAL_MODE=WAL

# ============================================================
# PERFORMANCE & LOGGING
# ============================================================
# Log level: debug, info, warning, error
PB_LOG_LEVEL=info
# Enable detailed request logging
PB_DEBUG_MODE=false
# Query optimization
PB_QUERY_TIMEOUT=30000

# ============================================================
# COLLECTIONS & MIGRATIONS
# ============================================================
# Automatically run pending migrations on startup
PB_AUTO_MIGRATIONS=true
# Migrations directory (relative to app root)
PB_MIGRATIONS_DIR=./pb_migrations
# Hooks directory for custom backend logic
PB_HOOKS_DIR=./pb_hooks

# ============================================================
# BACKUP & RECOVERY
# ============================================================
# Enable automatic backups
PB_BACKUP_ENABLED=true
# Backup interval in minutes
PB_BACKUP_INTERVAL=1440
# Keep last N backups
PB_BACKUP_RETENTION=7

# ============================================================
# API RATE LIMITING (Backend Protection)
# ============================================================
# Enable rate limiting per IP
PB_RATE_LIMIT_ENABLED=true
# Requests per minute per IP
PB_RATE_LIMIT_RPM=300
# Burst requests per second
PB_RATE_LIMIT_BURST=10

# ============================================================
# SECURITY HEADERS
# ============================================================
# Enable CORS for trusted origins
PB_CORS_ENABLED=true
# Maximum request body size (bytes)
PB_MAX_BODY_SIZE=5242880  # 5MB
# Request timeout (milliseconds)
PB_REQUEST_TIMEOUT=30000

# ============================================================
# STORAGE & FILES
# ============================================================
# Enable file uploads
PB_FILE_UPLOAD_ENABLED=true
# Maximum file size (bytes)
PB_FILE_UPLOAD_MAX_SIZE=10485760  # 10MB
# Allowed file types (comma-separated MIME types)
PB_FILE_UPLOAD_TYPES=image/jpeg,image/png,image/webp,application/pdf,text/csv

# ============================================================
# MONITORING & HEALTH
# ============================================================
# Enable health check endpoint
PB_HEALTH_CHECK_ENABLED=true
# Health check interval (seconds)
PB_HEALTH_CHECK_INTERVAL=60

# ============================================================
# CACHE SETTINGS
# ============================================================
# Enable in-memory caching
PB_CACHE_ENABLED=true
# Cache TTL (seconds)
PB_CACHE_TTL=3600
